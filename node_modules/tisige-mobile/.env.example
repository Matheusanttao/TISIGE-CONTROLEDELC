# Copie este arquivo para .env e preencha com os valores do Supabase:
# Dashboard → Project Settings → API → Project URL e anon / publishable key
# Expo só lê variáveis prefixadas com EXPO_PUBLIC_
# Sem espaços antes/depois do =; URL e chave devem ser do MESMO projeto.
# Depois de editar: pare o Expo (Ctrl+C) e rode npm start de novo.

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable_aqui
